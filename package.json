{
  "name": "unified-ticket-platform",
  "version": "1.0.0",
  "description": "Unified Ticket Reselling Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "admin": "cd admin-app && npm run dev",
    "organizer": "cd organizer-app && npm run dev",
    "start-all": "concurrently \"npm run dev\" \"npm run client\" \"npm run admin\" \"npm run organizer\"",
    "start-all-modules": "node start-all-modules.js",
    "install-all": "npm install && cd client && npm install && cd ../admin-app && npm install && cd ../organizer-app && npm install",
    "seed": "node scripts/seed.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "tickets",
    "resale",
    "platform"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
